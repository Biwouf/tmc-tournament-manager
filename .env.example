# Variables d'environnement — Back-office TMC Tournament Manager
#
# Copier ce fichier en .env.local puis renseigner les valeurs du projet
# Supabase de DÉVELOPPEMENT. Ne jamais committer de valeurs réelles :
# .env et .env.local sont gitignorés.

# URL du projet Supabase (dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clé publique « anon » du projet Supabase (dashboard → Project Settings → API)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Environnement applicatif : development | production
# En local, toujours garder development (pointe sur le projet Supabase de dev).
# production est réservé aux déploiements.
VITE_ENV=development
